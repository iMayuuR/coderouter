# CodeRouter runtime
PORT=3000

# Default route target used by Claude Code when model is omitted.
# Format: provider/model-id
DEFAULT_MODEL=openrouter/anthropic/claude-3.5-sonnet

# Optional model presets for quick switching (1..5)
MODEL_1=openrouter/anthropic/claude-3.5-sonnet
MODEL_2=openai/gpt-4.1-mini
MODEL_3=groq/llama-3.3-70b-versatile
MODEL_4=mistral/mistral-large-latest
MODEL_5=openrouter/google/gemini-2.5-pro

# Which MODEL_n to use by default (1 to 5)
DEFAULT_MODEL_SLOT=1

# Auto-route target when an image appears in the input
VISION_MODEL=openrouter/qwen/qwen-2.5-vl-72b-instruct:free

# Optional preferred provider (openrouter, openai, groq, mistral, nvidia, google, anthropic)
PRIMARY_PROVIDER=openrouter

# Provider keys (set whichever you want to use)
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=
NIM_API_KEY=
GOOGLE_API_KEY=

# [OPTIONAL] @21st-dev/magic MCP — https://21st.dev
MAGIC_API_KEY=your-21st-dev-key-here