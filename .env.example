# ============================================================
# Claude Code + CodeRouter Configuration
# ============================================================
# In this repo use: npm run claude  OR  .\run-claude.ps1
# ============================================================

# --- PROVIDERS (Jan-style) ---

# Primary Provider (openrouter, anthropic, openai, etc.)
PRIMARY_PROVIDER=openrouter

# OpenRouter (Default)
# Get one at https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=sk-or-v1-your-api-key-here

# Direct Providers
# Add keys here to hit providers directly and bypass the OpenRouter proxy.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
MISTRAL_API_KEY=
GROQ_API_KEY=
GOOGLE_API_KEY=

# --- MODELS ---

# Model to use for all Claude Code roles
# Examples: anthropic/claude-3-7-sonnet, openai/gpt-4o, openrouter/free
CLAUDE_MODEL=openrouter/free

# [OPTIONAL FALLBACK] 
# The proxy automatically finds a free vision model for you.
VISION_MODEL=qwen/qwen-2.5-vl-72b-instruct:free

# --- OTHER ---

# [OPTIONAL] @21st-dev/magic MCP — https://21st.dev
MAGIC_API_KEY=your-21st-dev-key-here

# [OPTIONAL] Proxy file logging
# CODEROUTER_PROXY_DEBUG=1
