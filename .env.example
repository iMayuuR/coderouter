# ============================================================
# Claude Code + OpenRouter Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env        (Linux/Mac)
#   copy .env.example .env      (Windows CMD)
# ============================================================

# Your OpenRouter API Key (get one at https://openrouter.ai/settings/keys)
OPENROUTER_API_KEY=sk-or-v1-your-api-key-here

# Model to use for all Claude Code roles
# Browse models at: https://openrouter.ai/models
# Examples:
#   nvidia/nemotron-3-super-120b-a12b:free
#   qwen/qwen3.6-plus-preview:free
#   openai/sora-2-pro
#   google/veo-3.1
#   minimax/minimax-m2.5:free
#   nvidia/nemotron-3-nano-30b-a3b:free
#   nvidia/nemotron-nano-12b-v2-vl:free
#   z-ai/glm-4.5-air:free
CLAUDE_MODEL=openrouter/free

# [OPTIONAL] API Key for @21st-dev/magic MCP (get one at https://21st.dev)
MAGIC_API_KEY=your-21st-dev-key-here

# [OPTIONAL FALLBACK] The proxy automatically finds a free vision model for you.
# If no active free vision models are found dynamically, this final fallback is used:
VISION_MODEL=qwen/qwen-2.5-vl-72b-instruct:free
