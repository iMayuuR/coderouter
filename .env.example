# CodeRouter runtime
PORT=3000

# Default model (used when Claude Code sends claude-* models)
# Format: provider/model-id or provider::model-id
DEFAULT_MODEL=nvidia/nemotron-3-super-120b-a12b

# Model presets for quick switching (m1..m5)
MODEL_1=nvidia::openai/gpt-oss-120b
MODEL_2=nvidia::google/gemma-4-31b-it
MODEL_3=nvidia::moonshotai/kimi-k2.5
MODEL_4=nvidia::nvidia/nemotron-3-super-120b-a12b
MODEL_5=nvidia::z-ai/glm4.7

# Custom aliases — use these in the /model picker
ALIAS_gpt=nvidia::openai/gpt-oss-120b
ALIAS_gemma=nvidia::google/gemma-4-31b-it
ALIAS_kimi=nvidia::moonshotai/kimi-k2.5
ALIAS_nemotron=nvidia/nemotron-3-super-120b-a12b
ALIAS_glm=nvidia::z-ai/glm4.7

# Auto-route target when an image appears in the input
VISION_MODEL=nvidia/nemotron-3-super-120b-a12b

# Primary provider (openrouter, openai, groq, mistral, nvidia, google, anthropic)
PRIMARY_PROVIDER=nvidia

# Provider API keys (Set whichever you want to use)
# NVIDIA Build: https://build.nvidia.com
NIM_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=
GOOGLE_API_KEY=

# [OPTIONAL] @21st-dev/magic MCP — https://21st.dev
MAGIC_API_KEY=your-21st-dev-key-here