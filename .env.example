# ============================================================
# Claude Code + OpenRouter Configuration
# ============================================================
# In this repo use: npm run claude  OR  .\run-claude.ps1  (not plain npx claude —
# that skips the local proxy and breaks OpenRouter.)
#
# Launchers set CLAUDE_CODE_DISABLE_EXPERIMENTAL_BETAS=1 so Claude Code does not
# request context-management-2025-06-27 (OpenRouter returns 400 for it).
# ============================================================
# Copy ONE of these templates to .env (never commit .env):
#   cp .env.example .env
#   copy .env.example .env
# Or the same layout:
#   cp install-global-skills.example.env .env
#
# install-global-skills.example.env is the user-facing template for keys + model
# (placeholders only — safe in git).
# ============================================================

# Your OpenRouter API Key (get one at https://openrouter.ai/settings/keys)
OPENROUTER_API_KEY=sk-or-v1-your-api-key-here

# Model to use for all Claude Code roles
# Browse models at: https://openrouter.ai/models
# Examples:
#   nvidia/nemotron-3-super-120b-a12b:free
#   qwen/qwen3.6-plus-preview:free
#   openai/sora-2-pro
#   google/veo-3.1
#   minimax/minimax-m2.5:free
#   nvidia/nemotron-3-nano-30b-a3b:free
#   nvidia/nemotron-nano-12b-v2-vl:free
#   z-ai/glm-4.5-air:free
CLAUDE_MODEL=openrouter/free

# [OPTIONAL] @21st-dev/magic MCP — https://21st.dev — or run: npm run setup:21st
# After setting the key: node install-global-skills.js (needs ~/.claude.json — run Claude Code once first).
# Writes user-scope MCP to ~/.claude.json top-level mcpServers. Restart Claude Code / IDE to see it in /mcp.
MAGIC_API_KEY=your-21st-dev-key-here

# [OPTIONAL] Proxy file logging — only when debugging (creates proxy-debug.log in repo folder)
# CODEROUTER_PROXY_DEBUG=1

# [OPTIONAL FALLBACK] The proxy automatically finds a free vision model for you.
# If no active free vision models are found dynamically, this final fallback is used:
VISION_MODEL=qwen/qwen-2.5-vl-72b-instruct:free
