{
  "__comment__": "Local config for CodeRouter + Claude Code CLI.",
  "project": {
    "name": "CodeRouter",
    "year": "2026",
    "description": "No-EXE, multi-provider router for Claude Code"
  },
  "providers": {
    "openrouter": {
      "enabled": true,
      "api_key_env": "OPENROUTER_API_KEY"
    },
    "openai": {
      "enabled": false,
      "api_key_env": "OPENAI_API_KEY"
    },
    "anthropic": {
      "enabled": false,
      "api_key_env": "ANTHROPIC_API_KEY"
    },
    "mistral": {
      "enabled": false,
      "api_key_env": "MISTRAL_API_KEY"
    },
    "groq": {
      "enabled": false,
      "api_key_env": "GROQ_API_KEY"
    },
    "nvidia": {
      "enabled": false,
      "api_key_env": "NIM_API_KEY"
    },
    "google": {
      "enabled": false,
      "api_key_env": "GOOGLE_API_KEY"
    }
  },
  "routing": {
    "primary_provider": "openrouter",
    "default_model": "openrouter/anthropic/claude-3.5-sonnet",
    "vision_model": "openrouter/qwen/qwen-2.5-vl-72b-instruct:free"
  },
  "claude_code_cli": {
    "anthropic_base_url": "http://127.0.0.1:3000",
    "anthropic_auth_token": "sk-ant-api03-coderouter-1234567890"
  },
  "setup_instructions": {
    "step_1": "Set provider keys in .env.",
    "step_2": "Run npm install and install-global-coderouter.ps1 once.",
    "step_3": "Restart terminal and use coderouter from any repo."
  }
}